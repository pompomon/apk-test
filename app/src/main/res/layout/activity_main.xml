<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/maze_root_background">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragmentGameHost"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/topOverlay"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/maze_top_overlay_background"
        android:orientation="vertical"
        android:padding="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3">

            <Spinner
                android:id="@+id/spinnerPlayerPolicy"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:contentDescription="@string/spinner_player_policy_description" />

            <Spinner
                android:id="@+id/spinnerNpcPolicy"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:contentDescription="@string/spinner_npc_policy_description" />

            <Spinner
                android:id="@+id/spinnerDifficulty"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:contentDescription="@string/spinner_difficulty_description" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonApply"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/apply" />

            <Button
                android:id="@+id/buttonPause"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/pause_resume" />

            <Button
                android:id="@+id/buttonRestart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/restart" />
        </LinearLayout>

        <TextView
            android:id="@+id/textStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/status_default"
            android:textColor="@color/maze_status_text"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/textSpeed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/speed_default"
            android:textColor="@color/maze_speed_text"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/textPowerUps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/powerups_default"
            android:textColor="@color/maze_speed_text"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:background="@color/maze_bottom_overlay_background"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/maze_dpad_container_padding"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <Button
            android:id="@+id/buttonUp"
            android:layout_width="@dimen/maze_dpad_button_width"
            android:layout_height="@dimen/maze_dpad_button_height"
            android:backgroundTint="@color/maze_dpad_button_background"
            android:contentDescription="@string/move_up_description"
            android:text="@string/move_up"
            android:textColor="@color/maze_dpad_button_text"
            android:textSize="@dimen/maze_dpad_button_text_size" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonLeft"
                android:layout_width="@dimen/maze_dpad_button_width"
                android:layout_height="@dimen/maze_dpad_button_height"
                android:backgroundTint="@color/maze_dpad_button_background"
                android:contentDescription="@string/move_left_description"
                android:text="@string/move_left"
                android:textColor="@color/maze_dpad_button_text"
                android:textSize="@dimen/maze_dpad_button_text_size" />

            <Button
                android:id="@+id/buttonDown"
                android:layout_width="@dimen/maze_dpad_button_width"
                android:layout_height="@dimen/maze_dpad_button_height"
                android:layout_marginStart="@dimen/maze_dpad_button_gap"
                android:backgroundTint="@color/maze_dpad_button_background"
                android:contentDescription="@string/move_down_description"
                android:text="@string/move_down"
                android:textColor="@color/maze_dpad_button_text"
                android:textSize="@dimen/maze_dpad_button_text_size" />

            <Button
                android:id="@+id/buttonRight"
                android:layout_width="@dimen/maze_dpad_button_width"
                android:layout_height="@dimen/maze_dpad_button_height"
                android:layout_marginStart="@dimen/maze_dpad_button_gap"
                android:backgroundTint="@color/maze_dpad_button_background"
                android:contentDescription="@string/move_right_description"
                android:text="@string/move_right"
                android:textColor="@color/maze_dpad_button_text"
                android:textSize="@dimen/maze_dpad_button_text_size" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
