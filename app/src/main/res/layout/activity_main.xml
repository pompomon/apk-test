<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/maze_root_background">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragmentGameHost"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomControls"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/buttonMenu"
        android:layout_width="@dimen/maze_menu_button_size"
        android:layout_height="@dimen/maze_menu_button_size"
        android:layout_margin="@dimen/maze_menu_button_margin"
        android:background="@drawable/bg_menu_button"
        android:contentDescription="@string/menu_button_description"
        android:padding="@dimen/maze_menu_button_padding"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_menu_hamburger"
        app:layout_constraintEnd_toEndOf="@id/fragmentGameHost"
        app:layout_constraintTop_toTopOf="@id/fragmentGameHost" />

    <LinearLayout
        android:id="@+id/bottomControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layoutDirection="ltr"
        android:layout_margin="8dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/maze_dpad_container_padding"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/fragmentGameHost">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Space
                android:layout_width="@dimen/maze_dpad_button_width"
                android:layout_height="@dimen/maze_dpad_button_height" />

            <Button
                android:id="@+id/buttonUp"
                android:layout_width="@dimen/maze_dpad_button_width"
                android:layout_height="@dimen/maze_dpad_button_height"
                android:layout_marginStart="@dimen/maze_dpad_button_gap"
                android:backgroundTint="@color/maze_dpad_button_background"
                android:contentDescription="@string/move_up_description"
                android:text="@string/move_up"
                android:textColor="@color/maze_dpad_button_text"
                android:textSize="@dimen/maze_dpad_button_text_size" />

            <ToggleButton
                android:id="@+id/buttonAuto"
                android:layout_width="@dimen/maze_dpad_button_width"
                android:layout_height="@dimen/maze_dpad_button_height"
                android:layout_marginStart="@dimen/maze_dpad_button_gap"
                android:backgroundTint="@color/maze_dpad_button_background"
                android:contentDescription="@string/auto_move_description"
                android:text="@string/auto_move"
                android:textColor="@color/maze_dpad_button_text"
                android:textOff="@string/auto_move"
                android:textOn="@string/auto_move"
                android:textSize="@dimen/maze_dpad_button_text_size" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonLeft"
                android:layout_width="@dimen/maze_dpad_button_width"
                android:layout_height="@dimen/maze_dpad_button_height"
                android:backgroundTint="@color/maze_dpad_button_background"
                android:contentDescription="@string/move_left_description"
                android:text="@string/move_left"
                android:textColor="@color/maze_dpad_button_text"
                android:textSize="@dimen/maze_dpad_button_text_size" />

            <Button
                android:id="@+id/buttonDown"
                android:layout_width="@dimen/maze_dpad_button_width"
                android:layout_height="@dimen/maze_dpad_button_height"
                android:layout_marginStart="@dimen/maze_dpad_button_gap"
                android:backgroundTint="@color/maze_dpad_button_background"
                android:contentDescription="@string/move_down_description"
                android:text="@string/move_down"
                android:textColor="@color/maze_dpad_button_text"
                android:textSize="@dimen/maze_dpad_button_text_size" />

            <Button
                android:id="@+id/buttonRight"
                android:layout_width="@dimen/maze_dpad_button_width"
                android:layout_height="@dimen/maze_dpad_button_height"
                android:layout_marginStart="@dimen/maze_dpad_button_gap"
                android:backgroundTint="@color/maze_dpad_button_background"
                android:contentDescription="@string/move_right_description"
                android:text="@string/move_right"
                android:textColor="@color/maze_dpad_button_text"
                android:textSize="@dimen/maze_dpad_button_text_size" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
