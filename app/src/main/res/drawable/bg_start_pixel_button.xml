<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <layer-list>
            <item
                android:left="@dimen/start_menu_button_pixel_offset"
                android:top="@dimen/start_menu_button_pixel_offset">
                <shape android:shape="rectangle">
                    <solid android:color="@color/start_menu_pixel_button_shadow_disabled" />
                </shape>
            </item>
            <item
                android:right="@dimen/start_menu_button_pixel_offset"
                android:bottom="@dimen/start_menu_button_pixel_offset">
                <shape android:shape="rectangle">
                    <solid android:color="@color/start_menu_pixel_button_background_disabled" />
                    <stroke
                        android:width="@dimen/start_menu_button_pixel_border"
                        android:color="@color/start_menu_pixel_button_border_disabled" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_pressed="true">
        <layer-list>
            <item
                android:left="@dimen/start_menu_button_pixel_offset"
                android:top="@dimen/start_menu_button_pixel_offset">
                <shape android:shape="rectangle">
                    <solid android:color="@color/start_menu_pixel_button_shadow" />
                </shape>
            </item>
            <item
                android:right="@dimen/start_menu_button_pixel_offset"
                android:bottom="@dimen/start_menu_button_pixel_offset">
                <shape android:shape="rectangle">
                    <solid android:color="@color/start_menu_pixel_button_background_pressed" />
                    <stroke
                        android:width="@dimen/start_menu_button_pixel_border"
                        android:color="@color/start_menu_pixel_button_border" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item
                android:left="@dimen/start_menu_button_pixel_offset"
                android:top="@dimen/start_menu_button_pixel_offset">
                <shape android:shape="rectangle">
                    <solid android:color="@color/start_menu_pixel_button_shadow" />
                </shape>
            </item>
            <item
                android:right="@dimen/start_menu_button_pixel_offset"
                android:bottom="@dimen/start_menu_button_pixel_offset">
                <shape android:shape="rectangle">
                    <solid android:color="@color/start_menu_pixel_button_background" />
                    <stroke
                        android:width="@dimen/start_menu_button_pixel_border"
                        android:color="@color/start_menu_pixel_button_border" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
